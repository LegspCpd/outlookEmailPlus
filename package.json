{
  "name": "outlook-email-plus",
  "version": "2.7.0",
  "description": "Outlook Email Plus — Cloudflare Workers 版",
  "main": "src/index.js",
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "scripts": {
    "dev": "wrangler dev",
    "deploy:preview": "wrangler deploy --env preview",
    "deploy:production": "wrangler deploy --env production",
    "test": "echo \"Use a scoped test script, for example: npm run test:browser-extension\" && exit 1",
    "test:browser-extension": "jest --runInBand --config tests/browser-extension/jest.config.js",
    "test:worker": "vitest run --config vitest.config.mjs",
    "cf-typegen": "wrangler types"
  },
  "keywords": ["outlook", "email", "cloudflare", "workers"],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260722.1",
    "wrangler": "^4.114.0"
  },
  "dependencies": {}
}
